generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  DIRECTEUR
  SUPERVISEUR
  CAISSIER
  AGENT_CREDIT
  COMPTABLE
  AUDITEUR
}

enum TypeClient {
  INDIVIDUEL
  ENTREPRISE
}

enum StatutClient {
  ACTIF
  INACTIF
  SUSPENDU
  BLACKLISTE
}

enum TypeCompte {
  EPARGNE
  COURANT
  TERME
  JOINT
  MICRO_EPARGNE
  TONTINE
  RETRAITE
  JEUNESSE
  CREDIT
}

enum StatutCompte {
  ACTIF
  INACTIF
  SUSPENDU
  CLOTURE
}

enum Devise {
  HTG
  USD
}

enum TypeTransaction {
  DEPOT
  RETRAIT
  VIREMENT_DEBIT
  VIREMENT_CREDIT
  DECAISSEMENT_PRET
  REMBOURSEMENT_PRET
  FRAIS
  INTERET
  AJUSTEMENT
}

enum StatutTransaction {
  EN_ATTENTE
  VALIDEE
  REJETEE
  ANNULEE
}

enum StatutSession {
  OUVERTE
  FERMEE
}

enum StatutPret {
  EN_ATTENTE
  APPROUVE
  DECAISSE
  EN_COURS
  SOLDE
  EN_RETARD
  REJETE
  ANNULE
}

enum TypeAmortissement {
  DEGRESSIF
  CONSTANT
  IN_FINE
}

enum StatutLignePret {
  EN_ATTENTE
  PARTIELLEMENT_PAYE
  PAYE
  EN_RETARD
}

enum TypeRemboursement {
  MENSUALITE
  ANTICIPEE
  PARTIELLE
  RETENUE_SALAIRE
}

enum TypeCompteComptable {
  ACTIF
  PASSIF
  CHARGE
  PRODUIT
  CAPITAUX
}

enum TypeGarantie {
  HYPOTHEQUE
  NANTISSEMENT
  CAUTION
  GAGE
  AUTRE
}

enum StatutGarantie {
  ACTIVE
  LEVEE
  SAISIE
}

enum FrequenceEpargne {
  HEBDOMADAIRE
  MENSUEL
  BIMESTRIEL
  TRIMESTRIEL
}

enum StatutEmploye {
  ACTIF
  INACTIF
  CONGE
  SUSPENDU
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  CONSULTANT
}

enum StatutContrat {
  ACTIF
  EXPIRE
  RESILIE
}

enum TypeConge {
  ANNUEL
  MALADIE
  MATERNITE
  PATERNITE
  SANS_SOLDE
  AUTRE
}

enum StatutConge {
  EN_ATTENTE
  APPROUVE
  REFUSE
  ANNULE
}

enum StatutPaie {
  BROUILLON
  VALIDE
  PAYE
}

enum ModeReglement {
  VIREMENT_BANKA
  ESPECES
}

enum StatutAvance {
  EN_ATTENTE
  DEDUITE
  ANNULEE
}

enum TypeElement {
  PRIME
  BONUS
  INDEMNITE
  RETENUE
  HEURE_SUP
}

enum StatutPointage {
  PRESENT
  ABSENT
  RETARD
  DEMI_JOURNEE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Utilisateur {
  id         String   @id @default(cuid())
  email      String   @unique
  motDePasse String
  nom        String
  prenom     String
  role       UserRole
  actif            Boolean  @default(true)
  telephone        String?
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  agenceId         String?
  agence     Agence?  @relation(fields: [agenceId], references: [id])

  transactionsCreees   Transaction[]       @relation("TransactionCreateur")
  transactionsValidees Transaction[]       @relation("TransactionValidateur")
  sessionsOuvertes     SessionCaisse[]     @relation("SessionOuverture")
  sessionsFermees      SessionCaisse[]     @relation("SessionFermeture")
  pretsCreees          Pret[]              @relation("PretAgentCredit")
  pretsValides         Pret[]              @relation("PretValidateur")
  remboursements       RemboursementPret[]
  ecritures            EcritureComptable[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  mandatsCrees         MandatCompte[]
  garantiesCrees       Garantie[]
  epargnesCrees        EpargneProgrammee[]
  avancesCrees         AvanceSalaire[]     @relation("AvanceCreePar")
  fichesPaieValidees   FichePaie[]         @relation("FicheValide")
  elementsVariablesCrees ElementVariable[] @relation("ElementVariableCreePar")
  pointagesCrees         PointageEmploye[]    @relation("PointageCreePar")
  employe                Employe?
  passwordResetTokens    PasswordResetToken[]
  transfertsTresorerieCrees TransfertTresorerie[] @relation("TransfertCreateur")
  transfertsTresorerieRecus TransfertTresorerie[] @relation("TransfertRecepteur")
  documentsCrees            Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agenceId])
  @@index([role, actif])
  @@map("utilisateurs")
}

model PasswordResetToken {
  id            String      @id @default(cuid())
  token         String      @unique
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  used          Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([utilisateurId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Agence {
  id        String  @id @default(cuid())
  code      String  @unique
  nom       String
  adresse   String?
  telephone String?
  actif     Boolean @default(true)

  utilisateurs Utilisateur[]
  comptes      Compte[]
  prets        Pret[]
  sessions     SessionCaisse[]
  employes     Employe[]
  caisses               CaisseAgence[]
  transactionsExecutees Transaction[]        @relation("TransactionAgenceExecution")
  transfertsEnvoyes     TransfertTresorerie[] @relation("TransfertSource")
  transfertsRecus       TransfertTresorerie[] @relation("TransfertDest")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agences")
}

// Solde de cash physique par agence et par devise — source de vérité indépendante des sessions
// journalières (contrairement à SessionCaisse.soldeOuverture, qui n'était jusqu'ici qu'une saisie
// libre sans mémoire d'un jour sur l'autre)
model CaisseAgence {
  id            String   @id @default(cuid())
  agenceId      String
  agence        Agence   @relation(fields: [agenceId], references: [id])
  devise        Devise
  solde         Decimal  @default(0) @db.Decimal(15, 2)
  plafondAlerte Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agenceId, devise])
  @@map("caisses_agence")
}

enum StatutTransfertTresorerie {
  ENVOYE
  RECU
  ANNULE
}

// Réapprovisionnement de caisse entre agences (ou vers/depuis le siège, agenceId = null) —
// mouvement de trésorerie interne, distinct d'un virement client : aucune écriture comptable
// classique (le plan comptable BANKA est consolidé au niveau banque, un seul compte 5700 Caisse)
model TransfertTresorerie {
  id             String  @id @default(cuid())
  reference      String  @unique
  agenceSourceId String?
  agenceSource   Agence? @relation("TransfertSource", fields: [agenceSourceId], references: [id])
  agenceDestId   String?
  agenceDest     Agence? @relation("TransfertDest", fields: [agenceDestId], references: [id])
  devise         Devise
  montant        Decimal @db.Decimal(15, 2)
  statut         StatutTransfertTresorerie @default(ENVOYE)
  notes          String?

  creeParId String
  creePar   Utilisateur  @relation("TransfertCreateur", fields: [creeParId], references: [id])
  recuParId String?
  recuPar   Utilisateur? @relation("TransfertRecepteur", fields: [recuParId], references: [id])

  envoyeAt DateTime  @default(now())
  recuAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agenceSourceId, statut])
  @@index([agenceDestId, statut])
  @@map("transferts_tresorerie")
}

model Client {
  id            String       @id @default(cuid())
  numeroClient  String       @unique
  type          TypeClient   @default(INDIVIDUEL)
  statut        StatutClient @default(ACTIF)

  // Individuel
  nom           String?
  prenom        String?
  dateNaissance DateTime?
  lieuNaissance String?

  // Entreprise
  raisonSociale String?
  nif           String?

  // Commun
  pieceIdentite String?
  numeroPiece   String?
  telephone     String
  email         String?
  adresse       String
  profession    String?
  photo         String?
  notes         String?

  comptes      Compte[]
  prets        Pret[]
  mandatsRecus MandatCompte[] @relation("MandataireCompte")
  documents    Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model Compte {
  id           String       @id @default(cuid())
  numeroCompte String       @unique
  type         TypeCompte
  devise       Devise       @default(HTG)
  solde        Decimal      @default(0) @db.Decimal(15, 2)
  soldeMinimum Decimal      @default(0) @db.Decimal(15, 2)
  statut       StatutCompte @default(ACTIF)
  intitule     String?
  tauxInteret  Decimal?     @db.Decimal(6, 4)
  dateEcheance DateTime?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  agenceId String
  agence   Agence @relation(fields: [agenceId], references: [id])

  transactionsDebit   Transaction[]       @relation("TransactionDebit")
  transactionsCredit  Transaction[]       @relation("TransactionCredit")
  mandats             MandatCompte[]
  epargnesSource      EpargneProgrammee[] @relation("EpargneSource")
  epargnesDest        EpargneProgrammee[] @relation("EpargneDestination")
  employes            Employe[]

  dateCloture DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([agenceId])
  @@index([statut])
  @@index([agenceId, statut])
  @@map("comptes")
}

model SessionCaisse {
  id             String        @id @default(cuid())
  date           DateTime      @default(now()) @db.Date
  agenceId       String
  agence         Agence        @relation(fields: [agenceId], references: [id])
  ouvertParId    String
  ouvertPar      Utilisateur   @relation("SessionOuverture", fields: [ouvertParId], references: [id])
  fermeParId     String?
  fermePar       Utilisateur?  @relation("SessionFermeture", fields: [fermeParId], references: [id])
  soldeOuverture Decimal       @db.Decimal(15, 2)
  soldeFermeture Decimal?      @db.Decimal(15, 2)
  // Écart entre le solde théorique (ouverture + mouvements de la session) et le comptage physique
  // saisi à la fermeture — tracé pour investigation plutôt que silencieusement absorbé
  ecartConstate      Decimal? @db.Decimal(15, 2)
  justificationEcart String?
  devise         Devise        @default(HTG)
  statut         StatutSession @default(OUVERTE)
  notes          String?

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agenceId, statut])
  @@map("sessions_caisse")
}

model Transaction {
  id         String            @id @default(cuid())
  reference  String            @unique
  type       TypeTransaction
  montant    Decimal           @db.Decimal(15, 2)
  devise     Devise
  soldeAvant Decimal           @db.Decimal(15, 2)
  soldeApres Decimal           @db.Decimal(15, 2)
  motif      String?
  statut     StatutTransaction @default(EN_ATTENTE)

  compteDebitId  String?
  compteDebit    Compte?  @relation("TransactionDebit", fields: [compteDebitId], references: [id])
  compteCreditId String?
  compteCredit   Compte?  @relation("TransactionCredit", fields: [compteCreditId], references: [id])

  sessionId String?
  session   SessionCaisse? @relation(fields: [sessionId], references: [id])

  // Traçabilité de l'agence ayant physiquement exécuté l'opération (peut différer de l'agence du
  // compte débité/crédité). Nullable : pas de backfill des transactions historiques.
  agenceExecutionId String?
  agenceExecution   Agence? @relation("TransactionAgenceExecution", fields: [agenceExecutionId], references: [id])

  creeParId    String
  creePar      Utilisateur  @relation("TransactionCreateur", fields: [creeParId], references: [id])
  valideParId  String?
  validePar    Utilisateur? @relation("TransactionValidateur", fields: [valideParId], references: [id])

  remboursementId String?           @unique
  remboursement   RemboursementPret? @relation(fields: [remboursementId], references: [id])

  ecritures EcritureComptable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Requêtes fréquentes : relevé compte, validation, stats, tendances
  @@index([compteDebitId])
  @@index([compteCreditId])
  @@index([statut])
  @@index([type])
  @@index([creeParId])
  @@index([sessionId])
  @@index([agenceExecutionId])
  @@index([createdAt])
  @@index([compteDebitId, statut])
  @@index([compteCreditId, statut])
  @@index([statut, createdAt])
  @@index([type, statut, createdAt])
  @@map("transactions")
}

model Pret {
  id                String            @id @default(cuid())
  reference         String            @unique
  clientId          String
  client            Client            @relation(fields: [clientId], references: [id])
  agenceId          String
  agence            Agence            @relation(fields: [agenceId], references: [id])
  montant           Decimal           @db.Decimal(15, 2)
  tauxMensuel       Decimal           @db.Decimal(6, 4)
  dureeMois         Int
  typeAmortissement TypeAmortissement @default(DEGRESSIF)
  devise            Devise            @default(HTG)
  objet             String?
  statut            StatutPret        @default(EN_ATTENTE)

  dateDemande      DateTime  @default(now())
  dateApprobation  DateTime?
  dateDecaissement DateTime?
  datePremierRdv   DateTime?
  dateDernierRdv   DateTime?

  agentCreditId String
  agentCredit   Utilisateur  @relation("PretAgentCredit", fields: [agentCreditId], references: [id])
  validateurId  String?
  validateur    Utilisateur? @relation("PretValidateur", fields: [validateurId], references: [id])

  montantTotal     Decimal @db.Decimal(15, 2)
  montantRembourse Decimal @default(0) @db.Decimal(15, 2)
  resteARegler     Decimal @db.Decimal(15, 2)
  notes            String?

  lignes         LignePret[]
  remboursements RemboursementPret[]
  garanties      Garantie[]
  fichesPaie     FichePaie[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([agenceId])
  @@index([statut])
  @@index([agentCreditId])
  @@index([agenceId, statut])
  @@map("prets")
}

model LignePret {
  id             String          @id @default(cuid())
  pretId         String
  pret           Pret            @relation(fields: [pretId], references: [id])
  numeroEcheance Int
  dateEcheance   DateTime
  capital        Decimal         @db.Decimal(15, 2)
  interet        Decimal         @db.Decimal(15, 2)
  mensualite     Decimal         @db.Decimal(15, 2)
  capitalRestant Decimal         @db.Decimal(15, 2)
  statut         StatutLignePret @default(EN_ATTENTE)

  createdAt DateTime @default(now())

  @@index([pretId])
  @@index([statut])
  @@index([dateEcheance, statut])
  @@map("lignes_pret")
}

model RemboursementPret {
  id       String            @id @default(cuid())
  pretId   String
  pret     Pret              @relation(fields: [pretId], references: [id])
  type     TypeRemboursement @default(MENSUALITE)
  montant  Decimal           @db.Decimal(15, 2)
  capital  Decimal           @db.Decimal(15, 2)
  interet  Decimal           @db.Decimal(15, 2)
  penalite Decimal           @default(0) @db.Decimal(15, 2)
  date     DateTime          @default(now())

  creeParId String
  creePar   Utilisateur @relation(fields: [creeParId], references: [id])

  transaction Transaction?

  createdAt DateTime @default(now())

  @@index([pretId])
  @@index([date])
  @@map("remboursements_pret")
}

model CompteComptable {
  id       String              @id @default(cuid())
  numero   String              @unique
  intitule String
  type     TypeCompteComptable
  parentId String?
  actif    Boolean             @default(true)

  ecrituresDebit  EcritureComptable[] @relation("EcritureDebit")
  ecrituresCredit EcritureComptable[] @relation("EcritureCredit")

  createdAt DateTime @default(now())

  @@map("comptes_comptables")
}

model EcritureComptable {
  id            String @id @default(cuid())
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  compteDebitId  String
  compteDebit    CompteComptable @relation("EcritureDebit", fields: [compteDebitId], references: [id])
  compteCreditId String
  compteCredit   CompteComptable @relation("EcritureCredit", fields: [compteCreditId], references: [id])

  montant  Decimal @db.Decimal(15, 2)
  libelle  String
  date     DateTime @default(now())

  creeParId String
  creePar   Utilisateur @relation(fields: [creeParId], references: [id])

  createdAt DateTime @default(now())

  // Critiques pour groupBy bilan/résultat et grand livre
  @@index([compteDebitId])
  @@index([compteCreditId])
  @@index([date])
  @@index([transactionId])
  @@index([compteDebitId, date])
  @@index([compteCreditId, date])
  @@map("ecritures_comptables")
}

model MandatCompte {
  id           String    @id @default(cuid())
  compteId     String
  compte       Compte    @relation(fields: [compteId], references: [id])
  mandataireId String
  mandataire   Client    @relation("MandataireCompte", fields: [mandataireId], references: [id])
  droits       String[]
  dateDebut    DateTime  @default(now())
  dateFin      DateTime?
  actif        Boolean   @default(true)
  notes        String?

  creeParId    String
  creePar      Utilisateur @relation(fields: [creeParId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([compteId])
  @@index([mandataireId])
  @@index([compteId, actif])
  @@map("mandats_compte")
}

model Configuration {
  id          String   @id @default(cuid())
  cle         String   @unique
  valeur      String
  description String?

  updatedAt DateTime @updatedAt

  @@map("configurations")
}

model Garantie {
  id            String         @id @default(cuid())
  pretId        String
  pret          Pret           @relation(fields: [pretId], references: [id])
  type          TypeGarantie
  statut        StatutGarantie @default(ACTIVE)
  description   String
  valeurEstimee Decimal?       @db.Decimal(15, 2)
  dateConstit   DateTime       @default(now())
  dateLevee     DateTime?
  notes         String?

  creeParId     String
  creePar       Utilisateur    @relation(fields: [creeParId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([pretId])
  @@index([statut])
  @@map("garanties")
}

enum TypeDocument {
  PIECE_IDENTITE
  JUSTIFICATIF_DOMICILE
  CONTRAT
  AUTRE
}

enum StatutDocument {
  ACTIF
  EXPIRE
  ARCHIVE
}

// Pièces jointes KYC du client (upload local, servi via /uploads — pas de compte cloud disponible
// dans cet environnement, même pattern que ANTENN/POSTA). L'expiration (pièce d'identité) est
// surveillée par un job quotidien (jobs/documentsExpiration.ts) plutôt que calculée à la volée.
model Document {
  id             String         @id @default(cuid())
  clientId       String
  client         Client         @relation(fields: [clientId], references: [id])
  type           TypeDocument
  nomFichier     String
  cheminFichier  String
  mimeType       String
  tailleOctets   Int
  dateExpiration DateTime?
  statut         StatutDocument @default(ACTIF)
  notes          String?

  creeParId String
  creePar   Utilisateur @relation(fields: [creeParId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([statut])
  @@index([dateExpiration])
  @@map("documents")
}

model EpargneProgrammee {
  id                String           @id @default(cuid())
  compteSourceId    String
  compteSource      Compte           @relation("EpargneSource", fields: [compteSourceId], references: [id])
  compteDestId      String
  compteDest        Compte           @relation("EpargneDestination", fields: [compteDestId], references: [id])
  montant           Decimal          @db.Decimal(15, 2)
  frequence         FrequenceEpargne
  prochainVersement DateTime
  actif             Boolean          @default(true)
  notes             String?
  nombreExecutions  Int              @default(0)
  derniereExecution DateTime?
  creeParId         String
  creePar           Utilisateur      @relation(fields: [creeParId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([actif, prochainVersement])
  @@index([compteSourceId])
  @@index([compteDestId])
  @@map("epargnes_programmees")
}

model Poste {
  id          String   @id @default(cuid())
  code        String   @unique
  intitule    String
  departement String?
  salaireMin  Decimal? @db.Decimal(15, 2)
  salaireMax  Decimal? @db.Decimal(15, 2)
  actif       Boolean  @default(true)
  employes    Employe[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("postes")
}

model Employe {
  id             String         @id @default(cuid())
  matricule      String         @unique
  biometricId    Int?           @unique
  nom            String
  prenom         String
  telephone      String?
  email          String?
  adresse        String?
  dateNaissance  DateTime?
  dateEmbauche   DateTime
  departement    String?
  statut         StatutEmploye  @default(ACTIF)
  salaireBrut    Decimal        @db.Decimal(15, 2)
  posteId        String
  poste          Poste          @relation(fields: [posteId], references: [id])
  compteId       String?
  compte         Compte?        @relation(fields: [compteId], references: [id])
  modeReglement  ModeReglement  @default(VIREMENT_BANKA)
  agenceId       String?
  agence         Agence?        @relation(fields: [agenceId], references: [id])
  utilisateurId  String?        @unique
  utilisateur    Utilisateur?   @relation(fields: [utilisateurId], references: [id])
  contrats       Contrat[]
  conges         Conge[]
  fichesPaie     FichePaie[]
  avances        AvanceSalaire[]
  elementsVariables ElementVariable[]
  pointages      PointageEmploye[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([statut])
  @@index([posteId])
  @@index([agenceId])
  @@map("employes")
}

model Contrat {
  id          String        @id @default(cuid())
  reference   String        @unique
  employeId   String
  employe     Employe       @relation(fields: [employeId], references: [id])
  type        TypeContrat
  statut      StatutContrat @default(ACTIF)
  dateDebut   DateTime
  dateFin     DateTime?
  salaireBrut Decimal       @db.Decimal(15, 2)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([employeId])
  @@index([statut])
  @@map("contrats")
}

model Conge {
  id         String      @id @default(cuid())
  employeId  String
  employe    Employe     @relation(fields: [employeId], references: [id])
  type       TypeConge
  statut     StatutConge @default(EN_ATTENTE)
  dateDebut  DateTime
  dateFin    DateTime
  nbJours    Int
  motif      String?
  commentaire String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([employeId])
  @@index([statut])
  @@map("conges")
}

model FichePaie {
  id              String        @id @default(cuid())
  reference       String        @unique
  employeId       String
  employe         Employe       @relation(fields: [employeId], references: [id])
  periode         String
  salaireBrut     Decimal       @db.Decimal(15, 2)
  cotisations     Decimal       @default(0) @db.Decimal(15, 2)
  avanceDeduite   Decimal       @default(0) @db.Decimal(15, 2)
  creditDeduit    Decimal       @default(0) @db.Decimal(15, 2)
  // Prêt sur lequel creditDeduit a été calculé — nécessaire pour appliquer la retenue au bon prêt
  // au moment du paiement (voir rh.service.ts::payerSalaires + pret.service.ts::appliquerRetenueSalariale)
  pretId          String?
  pret            Pret?         @relation(fields: [pretId], references: [id])
  salaireNet      Decimal       @db.Decimal(15, 2)
  statut          StatutPaie    @default(BROUILLON)
  modeReglement   ModeReglement @default(VIREMENT_BANKA)
  details         Json?
  valideParId     String?
  validePar       Utilisateur?  @relation("FicheValide", fields: [valideParId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@unique([employeId, periode])
  @@index([statut])
  @@index([periode])
  @@map("fiches_paie")
}

model AvanceSalaire {
  id               String       @id @default(cuid())
  reference        String       @unique
  employeId        String
  employe          Employe      @relation(fields: [employeId], references: [id])
  montant          Decimal      @db.Decimal(15, 2)
  periodeDeduction String
  statut           StatutAvance @default(EN_ATTENTE)
  notes            String?
  creeParId        String
  creePar          Utilisateur  @relation("AvanceCreePar", fields: [creeParId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([employeId])
  @@index([statut])
  @@index([periodeDeduction])
  @@map("avances_salaire")
}

model ElementVariable {
  id          String      @id @default(cuid())
  employeId   String
  employe     Employe     @relation(fields: [employeId], references: [id])
  periode     String
  type        TypeElement
  libelle     String
  montant     Decimal     @db.Decimal(15, 2)
  notes       String?
  creeParId   String
  creePar     Utilisateur @relation("ElementVariableCreePar", fields: [creeParId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([employeId])
  @@index([periode])
  @@index([employeId, periode])
  @@map("elements_variables")
}

// Trace les écritures comptables qui ont échoué sans bloquer l'opération bancaire.
// Permet la réconciliation manuelle et l'alerte aux comptables.
model EcritureEchec {
  id            String    @id @default(cuid())
  debitNumero   String
  creditNumero  String
  montant       Decimal   @db.Decimal(15, 2)
  libelle       String
  erreur        String
  transactionId String?
  userId        String
  resolu        Boolean   @default(false)
  resoluAt      DateTime?
  resoluParId   String?
  createdAt     DateTime  @default(now())

  @@index([createdAt])
  @@index([resolu])
  @@map("ecritures_echec")
}

model TauxChange {
  id          String   @id @default(cuid())
  devise      String   // "USD", "EUR", etc.
  tauxAchat   Decimal  @db.Decimal(10, 4)
  tauxVente   Decimal  @db.Decimal(10, 4)
  actif       Boolean  @default(true)
  creeParId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([devise, actif])
  @@map("taux_change")
}

enum TypeAlerteAML {
  SEUIL_DECLARE       // Transaction dépassant le seuil réglementaire
  STRUCTURATION       // Plusieurs transactions sous le seuil en 24h (smurfing)
  MANDATAIRE_BLACKLIST
  VELOCITE_ELEVEE     // Nombre de transactions anormal sur courte période
}

model AlerteAML {
  id            String        @id @default(cuid())
  type          TypeAlerteAML
  compteId      String?
  clientId      String?
  transactionId String?
  montantTotal  Decimal?      @db.Decimal(15, 2)
  details       String
  statut        String        @default("NOUVELLE")
  traitePar     String?
  traiteAt      DateTime?
  createdAt     DateTime      @default(now())

  @@index([statut])
  @@index([compteId])
  @@index([clientId])
  @@index([createdAt])
  @@map("alertes_aml")
}

model AuditLog {
  id             String   @id @default(cuid())
  table          String
  action         String
  entiteId       String
  ancienneValeur Json?
  nouvelleValeur Json?
  utilisateurId  String
  utilisateur    Utilisateur @relation(fields: [utilisateurId], references: [id])
  ip             String?

  createdAt DateTime @default(now())

  @@index([utilisateurId])
  @@index([table, action])
  @@index([createdAt])
  @@index([table, createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id            String      @id @default(cuid())
  token         String      @unique
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  expiresAt     DateTime
  revoked       Boolean     @default(false)

  createdAt DateTime @default(now())

  @@index([utilisateurId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PointageDevice {
  id           String    @id @default(cuid())
  nom          String
  serialNumber String    @unique
  commKey      String
  actif        Boolean   @default(true)
  derniereSync DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  pointages    PointageEmploye[]

  @@map("pointage_devices")
}

model PointageEmploye {
  id            String          @id @default(cuid())
  employeId     String
  employe       Employe         @relation(fields: [employeId], references: [id])
  date          DateTime
  heureArrivee  DateTime?
  heureDepart   DateTime?
  statut        StatutPointage  @default(PRESENT)
  retardMinutes Int?
  notes         String?
  source        String          @default("MANUEL")
  deviceId      String?
  device        PointageDevice? @relation(fields: [deviceId], references: [id])
  creeParId     String?
  creePar       Utilisateur?    @relation("PointageCreePar", fields: [creeParId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([employeId, date])
  @@index([date])
  @@index([employeId])
  @@index([deviceId])
  @@map("pointages")
}
