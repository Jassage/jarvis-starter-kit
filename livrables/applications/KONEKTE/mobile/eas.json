{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://jarvis-starter-kit-production-f573.up.railway.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://jarvis-starter-kit-production-f573.up.railway.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://jarvis-starter-kit-production-f573.up.railway.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://jarvis-starter-kit-production-f573.up.railway.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://jarvis-starter-kit-production-f573.up.railway.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://jarvis-starter-kit-production-f573.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
