{
  "name": "konekte-backend",
  "version": "1.0.0",
  "description": "Backend de la plateforme de rencontres Konekte",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "prisma generate && tsc",
    "start": "npx prisma migrate deploy && node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.1",
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
