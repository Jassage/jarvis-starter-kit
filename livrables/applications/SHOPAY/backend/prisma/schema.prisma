// SHOPAY — Plateforme SaaS e-commerce multi-tenant (store builder)
// Prisma Schema — PostgreSQL
//
// Isolation multi-tenant : base partagée, `boutiqueId` posé directement (+ indexé) sur
// toute table interrogée directement filtrée par boutique (Product, Category, Order, Cart,
// Customer, AuditLog, Notification, Payment nullable). Les tables toujours accédées via leur
// parent (OrderItem, CartItem, ProductVariant, ProductImage) n'ont pas besoin d'un boutiqueId
// redondant : la portée est garantie par la relation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Plateforme / Tenant
// ─────────────────────────────────────────

enum PlatformRole {
  PLATFORM_SUPER_ADMIN
  BOUTIQUE_OWNER
  BOUTIQUE_STAFF
}

enum BoutiqueStatus {
  ACTIVE
  SUSPENDED
  PENDING_SETUP
}

enum MerchantPlan {
  FREE
  BASIC
  PRO
}

enum Department {
  OUEST
  NORD
  NORD_EST
  NORD_OUEST
  ARTIBONITE
  CENTRE
  SUD
  SUD_EST
  NIPPES
  GRANDE_ANSE
}

model Boutique {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  status       BoutiqueStatus @default(PENDING_SETUP)
  logoUrl      String?
  logoPublicId String?
  themeColor   String         @default("#0EA5E9")
  description  String?
  contactEmail String?
  contactPhone String?
  department   Department?
  commune      String?
  landmark     String?

  users                User[]
  products             Product[]
  categories           Category[]
  orders               Order[]
  carts                Cart[]
  customers            Customer[]
  merchantSubscription MerchantSubscription?
  auditLogs            AuditLog[]
  notifications        Notification[]
  payments             Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("boutiques")
}

model MerchantSubscription {
  id         String       @id @default(cuid())
  boutiqueId String       @unique
  boutique   Boutique     @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  plan       MerchantPlan @default(FREE)
  isActive   Boolean      @default(true)
  startDate  DateTime     @default(now())
  expiresAt  DateTime?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("merchant_subscriptions")
}

// ─────────────────────────────────────────
// Utilisateurs (marchands + admin plateforme)
// ─────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  role          PlatformRole @default(BOUTIQUE_OWNER)
  boutiqueId    String? // null uniquement pour PLATFORM_SUPER_ADMIN
  boutique      Boutique?    @relation(fields: [boutiqueId], references: [id])
  isActive      Boolean      @default(true)
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boutiqueId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// Catalogue
// ─────────────────────────────────────────

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Category {
  id         String   @id @default(cuid())
  boutiqueId String
  boutique   Boutique @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  products   Product[]

  createdAt DateTime @default(now())

  @@unique([boutiqueId, slug])
  @@index([boutiqueId])
  @@map("categories")
}

model Product {
  id          String        @id @default(cuid())
  boutiqueId  String
  boutique    Boutique      @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category?     @relation(fields: [categoryId], references: [id])
  name        String
  slug        String
  description String?
  basePrice   Decimal       @db.Decimal(12, 2)
  currency    String        @default("HTG")
  status      ProductStatus @default(DRAFT)
  trackStock  Boolean       @default(true)
  stockQty    Int           @default(0)

  images     ProductImage[]
  variants   ProductVariant[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([boutiqueId, slug])
  @@index([boutiqueId, status])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String?
  order     Int     @default(0)

  @@map("product_images")
}

model ProductVariant {
  id            String  @id @default(cuid())
  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku           String?
  optionsJson   Json // ex: {"Taille":"M","Couleur":"Rouge"}
  priceOverride Decimal? @db.Decimal(12, 2)
  stockQty      Int      @default(0)
  imageUrl      String?

  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([productId])
  @@map("product_variants")
}

// ─────────────────────────────────────────
// Clients (scopés par boutique)
// ─────────────────────────────────────────

model Customer {
  id         String      @id @default(cuid())
  boutiqueId String
  boutique   Boutique    @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  email      String
  password   String? // null pour un client checkout invité
  firstName  String?
  lastName   String?
  phone      String?
  department Department?
  commune    String?
  landmark   String?

  orders Order[]
  carts  Cart[]

  createdAt DateTime @default(now())

  @@unique([boutiqueId, email])
  @@index([boutiqueId])
  @@map("customers")
}

// ─────────────────────────────────────────
// Panier
// ─────────────────────────────────────────

model Cart {
  id         String    @id @default(cuid())
  boutiqueId String
  boutique   Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  sessionId  String? // panier anonyme avant checkout/connexion
  items      CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boutiqueId, sessionId])
  @@index([customerId])
  @@map("carts")
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int             @default(1)
  unitPrice Decimal         @db.Decimal(12, 2) // capturé au moment de l'ajout

  @@map("cart_items")
}

// ─────────────────────────────────────────
// Commandes
// ─────────────────────────────────────────

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id          String      @id @default(cuid())
  boutiqueId  String
  boutique    Boutique    @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  orderNumber String      @unique
  status      OrderStatus @default(PENDING_PAYMENT)

  items       OrderItem[]
  subtotal    Decimal     @db.Decimal(12, 2)
  shippingFee Decimal     @db.Decimal(12, 2) @default(0)
  total       Decimal     @db.Decimal(12, 2)
  currency    String      @default("HTG")

  // Acheteur + livraison (checkout invité : pas de Customer requis, capturé en ligne)
  buyerName  String
  buyerEmail String
  buyerPhone String
  department Department?
  commune    String?
  landmark   String?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boutiqueId, status, createdAt])
  @@map("orders")
}

model OrderItem {
  id                  String          @id @default(cuid())
  orderId             String
  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String
  product             Product         @relation(fields: [productId], references: [id])
  variantId           String?
  variant             ProductVariant? @relation(fields: [variantId], references: [id])
  productNameSnapshot String
  quantity            Int
  unitPrice           Decimal         @db.Decimal(12, 2)

  @@map("order_items")
}

// ─────────────────────────────────────────
// Paiements (généralisé : commande OU abonnement plateforme)
// ─────────────────────────────────────────

enum PaymentPurpose {
  ORDER
  PLATFORM_SUBSCRIPTION
}

enum PaymentMethod {
  STRIPE
  MONCASH
  MANUAL_PROOF
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id                     String                @id @default(cuid())
  purpose                PaymentPurpose
  boutiqueId             String? // null pour PLATFORM_SUBSCRIPTION
  boutique               Boutique?             @relation(fields: [boutiqueId], references: [id])
  orderId                String?
  order                  Order?                @relation(fields: [orderId], references: [id])
  merchantSubscriptionId String?
  merchantSubscription   MerchantSubscription? @relation(fields: [merchantSubscriptionId], references: [id])

  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("HTG")
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  providerRef String?
  metadata    Json? // { awaitingVerification, proof: {...} } comme LAKAY

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boutiqueId, createdAt])
  @@index([orderId])
  @@map("payments")
}

// ─────────────────────────────────────────
// Audit & notifications
// ─────────────────────────────────────────

model AuditLog {
  id         String    @id @default(cuid())
  boutiqueId String? // null pour une action au niveau plateforme
  boutique   Boutique? @relation(fields: [boutiqueId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  action     String
  entite     String
  entiteId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([boutiqueId, createdAt])
  @@map("audit_logs")
}

enum NotificationType {
  ORDER_PLACED
  ORDER_PAID
  PAYMENT_FAILED
  PLAN_UPGRADED
  PLAN_EXPIRING
  LOW_STOCK
  PAYMENT_PROOF_SUBMITTED
}

model Notification {
  id         String           @id @default(cuid())
  boutiqueId String?
  boutique   Boutique?        @relation(fields: [boutiqueId], references: [id])
  userId     String? // destinataire marchand, si applicable
  type       NotificationType
  title      String
  message    String
  data       Json?
  isRead     Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([boutiqueId, isRead, createdAt])
  @@map("notifications")
}
