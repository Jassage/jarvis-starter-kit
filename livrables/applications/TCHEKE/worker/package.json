{
  "name": "tcheke-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Worker TCHEKE : recuperation des tirages borlette (NY + FL), calcul des lots, ecriture Firestore, notifications push, taux BRH quotidien.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "backfill": "tsx --env-file=.env src/scripts/backfill.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo-server-sdk": "^3.10.0",
    "firebase-admin": "^12.6.0",
    "node-cron": "^3.0.3",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
