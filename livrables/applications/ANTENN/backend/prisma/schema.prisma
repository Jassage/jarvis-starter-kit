// ANTENN — Régie TV pour chaîne de streaming FAST (Haitech Solutions)
// Prisma Schema — PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ADMINISTRATEUR
  OPERATEUR_REGIE
}

enum TypeContenu {
  VIDEO_BOUCLE
  SPOT_PUBLICITAIRE
  HABILLAGE_LOGO
}

enum TypeCreneau {
  PROGRAMME
  MATCH_DIRECT
  PUB
}

enum StatutDiffusionMatch {
  PLANIFIE
  EN_COURS
  TERMINE
}

enum TypePackageSponsor {
  TITRE_MATCH
  BANDEAU
  HABILLAGE_PERMANENT
}

// Distingue une grille encore en cours d'édition (BROUILLON) de ce qui a été
// répercuté vers ErsatzTV (SYNCHRONISE) — cf. src/integrations/ersatztv.ts.
enum SyncStatus {
  BROUILLON
  SYNCHRONISE
}

// Un replay n'est jamais public par accident : il naît BROUILLON et un opérateur le
// publie explicitement (droits VOD à vérifier, URL d'enregistrement à saisir pour un
// match). RETIRE conserve la fiche sans l'exposer.
enum StatutReplay {
  BROUILLON
  PUBLIE
  RETIRE
}

enum PositionOverlay {
  HAUT_GAUCHE
  HAUT_DROITE
  BAS_GAUCHE
  BAS_DROITE
}

// ─────────────────────────────────────────
// CONFIGURATION DE LA CHAÎNE (singleton)
// ─────────────────────────────────────────

// Identité de la chaîne : nom + logo permanent affiché en continu par le player,
// indépendamment du programme (le "bug" d'une vraie chaîne TV). Une seule ligne
// (singleton géré en service via getOrCreate).
model ConfigChaine {
  id           String          @id @default(cuid())
  // Verrou du singleton au niveau base : toujours `true`, contrainte d'unicité.
  // Sans lui, deux appels concurrents à getConfig() sur une base neuve créent
  // chacun leur ligne (findFirst ne voit rien, les deux insèrent) et le logo de
  // chaîne apparaît ou disparaît selon la ligne que findFirst renvoie ensuite.
  singleton    Boolean         @unique @default(true)
  nomChaine    String          @default("ANTENN")
  logoUrl      String?
  logoPosition PositionOverlay @default(HAUT_DROITE)
  logoOpacite  Float           @default(0.9)
  logoActif    Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("config_chaine")
}

// ─────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nom       String
  role      Role     @default(OPERATEUR_REGIE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// SPONSORS
// ─────────────────────────────────────────

model Sponsor {
  id                String              @id @default(cuid())
  nomSponsor        String
  logoUrl           String?
  typePackage       TypePackageSponsor
  contactNom        String?
  contactTelephone  String?
  dateDebutContrat  DateTime
  dateFinContrat    DateTime
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  contenus         Contenu[]
  matchsTitre      Match[]
  incrustations    IncrustationLogo[]

  @@map("sponsors")
}

// ─────────────────────────────────────────
// CONTENUS
// ─────────────────────────────────────────

model Contenu {
  id             String      @id @default(cuid())
  titre          String
  typeContenu    TypeContenu
  urlFichier     String
  dureeSecondes  Int
  sponsorId      String?
  sponsor        Sponsor?    @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  // Contenu de repli (filet anti-écran-noir) : rejoué comme "à l'antenne" quand la
  // grille synchronisée a un trou. Au plus un actif à la fois (invariant en service).
  estContenuDeRepli Boolean  @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  creneaux CreneauGrille[]

  @@map("contenus")
}

// ─────────────────────────────────────────
// MATCHS
// ─────────────────────────────────────────

model Match {
  id                  String                @id @default(cuid())
  nomEvenement        String
  equipes             String
  dateHeurePrevue     DateTime
  statutDiffusion     StatutDiffusionMatch  @default(PLANIFIE)
  ingestUrlRtmp       String?
  sponsorPrincipalId  String?
  sponsorPrincipal    Sponsor?              @relation(fields: [sponsorPrincipalId], references: [id], onDelete: SetNull)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  creneaux         CreneauGrille[]
  incrustations    IncrustationLogo[]
  bandeaux         BandeauSponsor[]
  diffusionLogs    DiffusionLog[]
  replays          Replay[]

  @@map("matchs")
}

// ─────────────────────────────────────────
// GRILLE
// ─────────────────────────────────────────

model CreneauGrille {
  id              String       @id @default(cuid())
  dateHeureDebut  DateTime
  dateHeureFin    DateTime
  typeCreneau     TypeCreneau
  contenuId       String?
  contenu         Contenu?     @relation(fields: [contenuId], references: [id], onDelete: SetNull)
  matchId         String?
  match           Match?       @relation(fields: [matchId], references: [id], onDelete: SetNull)
  syncStatus      SyncStatus   @default(BROUILLON)
  syncedAt        DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  incrustations  IncrustationLogo[]
  bandeaux       BandeauSponsor[]
  diffusionLogs  DiffusionLog[]
  replay         Replay?

  @@index([dateHeureDebut])
  @@index([dateHeureFin])
  @@map("creneaux_grille")
}

// ─────────────────────────────────────────
// HABILLAGE PUBLICITAIRE
// ─────────────────────────────────────────

model IncrustationLogo {
  id          String           @id @default(cuid())
  creneauId   String?
  creneau     CreneauGrille?   @relation(fields: [creneauId], references: [id], onDelete: Cascade)
  matchId     String?
  match       Match?           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sponsorId   String
  sponsor     Sponsor          @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  logoUrl     String
  position    PositionOverlay  @default(BAS_DROITE)
  opacite     Float            @default(0.85)
  actif       Boolean          @default(true)
  createdAt   DateTime         @default(now())

  @@map("incrustations_logo")
}

model BandeauSponsor {
  id                  String          @id @default(cuid())
  creneauId           String?
  creneau             CreneauGrille?  @relation(fields: [creneauId], references: [id], onDelete: Cascade)
  matchId             String?
  match               Match?          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  // [{ texte, logoUrl?, sponsorId }] — liste hétérogène, JSON plus simple qu'une
  // table de jointure pour un simple bandeau défilant sans besoin de requêtage fin.
  items               Json
  vitesseDefilement   Int             @default(60)
  actif               Boolean         @default(true)
  createdAt           DateTime        @default(now())

  @@map("bandeaux_sponsor")
}

// ─────────────────────────────────────────
// RAPPORTS DE DIFFUSION
// ─────────────────────────────────────────

model DiffusionLog {
  id                       String          @id @default(cuid())
  creneauId                String?
  creneau                  CreneauGrille?  @relation(fields: [creneauId], references: [id], onDelete: SetNull)
  matchId                  String?
  match                    Match?          @relation(fields: [matchId], references: [id], onDelete: SetNull)
  dateHeureReelle          DateTime
  dureeVisionneeEstimee    Int
  nombreVuesEstimees       Int
  createdAt                DateTime        @default(now())

  @@index([creneauId])
  @@index([matchId])
  @@map("diffusion_logs")
}

// ─────────────────────────────────────────
// REPLAY / VOD
// ─────────────────────────────────────────

// Ré-écoute à la demande d'un programme déjà passé à l'antenne. Comme pour Contenu,
// ANTENN ne stocke ni ne transcode la vidéo : `urlVod` pointe vers un fichier déjà
// hébergé (CDN pour un programme, enregistrement MediaMTX pour un match direct).
// `creneauId` garde le lien avec ce qui a réellement été diffusé — c'est lui qui
// permet de rejouer l'habillage sponsor du créneau d'origine sur le replay.
model Replay {
  id            String        @id @default(cuid())
  titre         String
  description   String?
  urlVod        String
  vignetteUrl   String?
  dureeSecondes Int
  statut        StatutReplay  @default(BROUILLON)
  // Fenêtre de droits de diffusion (bornes optionnelles) : hors fenêtre, le replay
  // disparaît du catalogue public de lui-même, sans intervention d'un opérateur.
  disponibleDu  DateTime?
  disponibleAu  DateTime?
  nombreVues    Int           @default(0)
  publieAt      DateTime?
  // Un seul replay par créneau diffusé (les NULL multiples restent permis en Postgres).
  creneauId     String?        @unique
  creneau       CreneauGrille? @relation(fields: [creneauId], references: [id], onDelete: SetNull)
  matchId       String?
  match         Match?         @relation(fields: [matchId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([statut])
  @@map("replays")
}
