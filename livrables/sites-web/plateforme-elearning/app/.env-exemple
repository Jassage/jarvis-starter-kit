# =============================================================================
# .env-exemple - Variables d'environnement requises par l'app EduSpher
# =============================================================================
# Copier ce fichier en .env et renseigner les valeurs reelles (jamais commit).

# --- Base de donnees (Supabase Postgres via Supavisor) ---
DATABASE_URL=
DIRECT_URL=

# --- Auth.js (genere via: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))") ---
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Supabase (projet) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
