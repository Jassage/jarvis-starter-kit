# =============================================================================
# .env-exemple - Template public des variables d'environnement
# =============================================================================
#
# Copie ce fichier en ".env" et remplis les valeurs avec tes vraies clés API.
# Le fichier ".env" ne doit jamais être commit (voir .gitignore).
# =============================================================================

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Notion ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Google (APIs générales / OAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=

# --- YouTube Data API ---
YOUTUBE_API_KEY=

# --- Vercel ---
VERCEL_TOKEN=

# --- GitHub ---
GITHUB_TOKEN=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
